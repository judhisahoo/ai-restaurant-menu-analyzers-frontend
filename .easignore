# When this file exists, EAS uses ONLY these patterns (not .gitignore).
# Keep ignoring the same artifacts as .gitignore, but allow /android and /ios
# so the native project is uploaded for Gradle builds.

node_modules/
.expo/
dist/
web-build/
expo-env.d.ts
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
.metro-health-check*
npm-debug.*
yarn-debug.*
yarn-error.*
.DS_Store
*.pem
.env*.local
*.tsbuildinfo

# Native build outputs (regenerated on EAS)
android/.gradle/
android/**/build/
android/local.properties
ios/Pods/
ios/build/
